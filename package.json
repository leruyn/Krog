{
  "name": "RNBase",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "android:dev": "node ./scripts/run-android.js devDebug",
    "android:stag": "node ./scripts/run-android.js stagDebug",
    "android:prod": "node ./scripts/run-android.js prodDebug",
    "build:android:apk": "node ./scripts/build-android.js prod apk",
    "build:android:aab": "node ./scripts/build-android.js prod aab",
    "ios": "react-native run-ios --scheme \"RNBase-Dev\" --mode DevDebug",
    "ios:dev": "react-native run-ios --scheme \"RNBase-Dev\" --mode DevDebug",
    "ios:stag": "react-native run-ios --scheme \"RNBase-Stag\" --mode StagDebug",
    "ios:prod": "react-native run-ios --scheme \"RNBase-Prod\" --mode Debug",
    "start": "react-native start --host 0.0.0.0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/bottom-tabs": "^7.8.6",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@reduxjs/toolkit": "^2.11.2",
    "@shopify/restyle": "^2.4.5",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "expo-local-authentication": "^56.0.4",
    "expo-modules-core": "^56.0.14",
    "i18next": "^26.0.4",
    "lottie-react-native": "^7.3.4",
    "react": "19.2.3",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2",
    "react-native": "0.85.0",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-keychain": "^10.0.0",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "^0.9.1",
    "react-redux": "^9.2.0",
    "reselect": "^5.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@react-native/metro-config": "0.85.0",
    "@react-native/typescript-config": "0.85.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-redux": "^7.1.34",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
